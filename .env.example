# Public OpenClaw + ClawControl runtime Docker example.
# Copy this file to .env and adjust as needed for your host.

STACK_PROJECT_NAME=clawcontrol-openclaw-docker

# OpenClaw image used for both the gateway and the helper CLI container.
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_GATEWAY_PORT=18799
OPENCLAW_BROWSER_UI_PORT=18801
OPENCLAW_GATEWAY_TOKEN=change-me

# Published runtime package spec to bake into the runtime image.
# Use an exact semver for repeatable installs.
CLAWCONTROL_RUNTIME_NPM_SPEC=latest
CLAWCONTROL_RUNTIME_IMAGE=clawcontrol-runtime:docker-example

# Optional path overrides. Leave blank to use the repository defaults.
OPENCLAW_STATE_DIR=
OPENCLAW_WORKSPACE_DIR=
RUNTIME_STATE_DIR=
OPENCLAW_CONFIG_TEMPLATE=
